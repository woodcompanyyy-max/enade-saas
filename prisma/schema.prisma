// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Shift {
  MATUTINO
  NOTURNO
  EAD
}

model Course {
  id                String       @id @default(cuid())
  name              String       @unique
  category          String       // Bacharelado, Licenciatura, Tecnológico
  modality          String       // Presencial, Semipresencial, EaD
  enadeScore        Float        @default(0)
  nationalAvg       Float        @default(0)
  participationRate Float        @default(0)
  idd               Float        @default(0)
  riskLevel         String       @default("Médio") // Baixo, Médio, Alto
  userId            String?      // Optional for backward compatibility with mock/dev
  user              User?        @relation(fields: [userId], references: [id])
  students          Student[]
  assessments       Assessment[]
  simulados         Simulado[]
  diagnosticos      Diagnostico[]
  results           StudentResult[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Student {
  id                 String          @id @default(cuid())
  ra                 String          @unique
  name               String
  email              String?
  shift              Shift           @default(EAD)
  courseId           String
  course             Course          @relation(fields: [courseId], references: [id])
  entryYear          Int?
  graduationYear     Int?
  lastSimulatedScore Float           @default(0)
  results            StudentResult[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model StudentResult {
  id              String      @id @default(cuid())
  studentId       String
  student         Student     @relation(fields: [studentId], references: [id])
  courseId        String
  simuladoId      String?
  simulado        Simulado?   @relation(fields: [simuladoId], references: [id])
  assessmentId    String?
  assessment      Assessment? @relation(fields: [assessmentId], references: [id])
  course          Course      @relation(fields: [courseId], references: [id])
  examType        String      // "simulado" ou "oficial"
  specificCorrect Int
  specificWrong   Int
  fgCorrect       Int
  fgWrong         Int
  totalCorrect    Int
  totalWrong      Int
  createdAt       DateTime    @default(now())
}

model Assessment {
  id            String          @id @default(cuid())
  year          Int
  courseId      String
  course        Course          @relation(fields: [courseId], references: [id])
  generalScore  Float
  idd           Float
  riskLevel     String
  participation Float           @default(0)
  results       StudentResult[]
  createdAt     DateTime        @default(now())
}

model Simulado {
  id            String          @id @default(cuid())
  name          String
  date          DateTime
  avg           Float           @default(0)
  participation Float           @default(0)
  status        String          @default("Agendado") // Agendado, Em andamento, Finalizado
  userId        String?
  user          User?           @relation(fields: [userId], references: [id])
  courseId      String
  course        Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  diagnosticos  Diagnostico[]
  results       StudentResult[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Diagnostico {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  simuladoId      String?
  simulado        Simulado? @relation(fields: [simuladoId], references: [id], onDelete: SetNull)
  scoreGeral      Float
  riskLevel       String   // Baixo, Médio, Alto
  trend           String   // Crescente, Estável, Em queda
  strengths       String   // JSON string array
  weaknesses      String   // JSON string array
  recommendations String   // JSON string array
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  role          String        @default("USER") // ADMIN, PROFESSOR, USER
  cursos        Course[]
  simulados     Simulado[]
  diagnosticos  Diagnostico[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
